{
  "name": "geulbit",
  "version": "1.1.0",
  "description": "`rhwp`를 브라우저 편집 엔진으로 활용하고, `claw-code`의 도구 지향 에이전트 발상을 차용한 한국어 문서 작성용 오피스 에이전트입니다.",
  "main": "electron/main.js",
  "scripts": {
    "desktop": "electron .",
    "desktop:dev": "electron .",
    "package:mac": "electron-builder --mac dmg zip",
    "release:github": "VERSION=$(node -p \"require('./package.json').version\") && gh release create \"v$VERSION\" dist-electron/*.dmg dist-electron/*.zip --repo hwkim3330/geulbit --generate-notes",
    "test": "node --check electron/main.js && node --check electron/preload.js && python3 -m py_compile app.py"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hwkim3330/geulbit.git"
  },
  "keywords": [
    "office",
    "hwp",
    "gemma",
    "electron",
    "macos"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/hwkim3330/geulbit/issues"
  },
  "homepage": "https://github.com/hwkim3330/geulbit#readme",
  "dependencies": {
    "systeminformation": "^5.27.11"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.hwkim.officeagentstaff",
    "productName": "Geulbit",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "static/**/*",
      "app.py",
      "README.md",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
